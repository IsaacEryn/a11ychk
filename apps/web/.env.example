# ── Supabase (https://supabase.com/dashboard → 프로젝트 → Settings → API) ──
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# 서버 전용 — 절대 클라이언트/저장소에 노출 금지
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── 내부 API 보호용 랜덤 시크릿 (openssl rand -hex 32 로 생성) ──
INTERNAL_API_SECRET=change-me

# ── 정기 스캔 크론 보호용 (Vercel Cron이 Authorization 헤더로 자동 전송) ──
CRON_SECRET=change-me-too

# ── (선택) GitHub 저장소 트래픽 수집용 토큰 — repo-stats 크론 ──
# 저장소 push 권한 계정의 fine-grained PAT(Administration: read) 또는 classic repo scope.
# 없으면 트래픽(조회·클론)은 건너뛰고 스타·포크만 기록.
# GITHUB_STATS_TOKEN=github_pat_...

# ── 로케일 맞춤 인증 메일 (Supabase Send Email Hook) ──
# RESEND_API_KEY: Resend API 키 (re_...)
# SEND_EMAIL_HOOK_SECRET: Supabase에서 Send Email 훅 등록 시 발급되는 v1,whsec_… 시크릿
# RESEND_API_KEY=re_...
# SEND_EMAIL_HOOK_SECRET=v1,whsec_...

# ── 인증 남용 방지 CAPTCHA (Cloudflare Turnstile) ──
# 사이트 키(공개)는 프론트에, 시크릿 키는 Supabase Auth → Settings → Captcha에 입력.
# 미설정 시 CAPTCHA 비활성(위젯 렌더 안 됨).
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAA...

# ── 사이트 URL (로컬: http://localhost:3000, 운영: https://a11ychk.com) ──
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── (선택) 로컬 개발용 크롬 실행 파일 경로 — 미지정 시 playwright 설치본 사용 ──
# A11YCHK_CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
