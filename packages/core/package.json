  "description": "A11y Check core engine — crawler, axe-core scanner, WCAG 2.2 + KWCAG 2.2 rule catalog, report aggregation, SSRF guard",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./catalog": "./src/catalog-entry.ts"
